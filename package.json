{
    "name": "shared-memory-mcp",
    "displayName": "Shared Memory MCP (Supabase BYODB)",
    "description": "Memoria compartida para agentes de IA (Roo Code, Cline, Cursor) usando el protocolo MCP y tu propio Supabase.",
    "version": "1.0.0",
    "publisher": "Olymp-ia",
    "license": "MIT",
    "icon": "icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/Cucholambr3ta/PROJ-SharedMemoryExtension.git"
    },
    "bugs": {
        "url": "https://github.com/Cucholambr3ta/PROJ-SharedMemoryExtension/issues"
    },
    "homepage": "https://github.com/Cucholambr3ta/PROJ-SharedMemoryExtension#readme",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "shared-memory-mcp.setupSupabase",
                "title": "Shared Memory: Configurar Supabase",
                "category": "Shared Memory MCP"
            },
            {
                "command": "shared-memory-mcp.copyServerPath",
                "title": "Shared Memory: Copiar ruta del servidor para Roo/Cline",
                "category": "Shared Memory MCP"
            },
            {
                "command": "shared-memory-mcp.copyMcpConfig",
                "title": "Shared Memory: Copiar configuración MCP para Roo/Cline",
                "category": "Shared Memory MCP"
            },
            {
                "command": "shared-memory-mcp.generateSql",
                "title": "Shared Memory: Generar SQL de inicialización",
                "category": "Shared Memory MCP"
            }
        ],
        "configuration": {
            "title": "Shared Memory MCP",
            "properties": {
                "sharedMemoryMcp.supabaseUrl": {
                    "type": "string",
                    "default": "",
                    "description": "URL de tu proyecto de Supabase."
                },
                "sharedMemoryMcp.machineId": {
                    "type": "string",
                    "default": "Agente-Desconocido",
                    "description": "Identificador único para esta máquina/usuario en la flota (ej. 'Dev-Juan', 'Laptop-Olympia')."
                },
                "sharedMemoryMcp.heartbeatInterval": {
                    "type": "integer",
                    "default": 60,
                    "description": "Intervalo en segundos para el heartbeat de presencia. Mínimo 30 segundos."
                },
                "sharedMemoryMcp.autoReadMessages": {
                    "type": "boolean",
                    "default": true,
                    "description": "Mostrar notificaciones de VS Code automáticamente cuando lleguen nuevos mensajes de la flota."
                },
                "sharedMemoryMcp.retentionDays": {
                    "type": "integer",
                    "default": 7,
                    "description": "Días que se conservarán los mensajes en Supabase antes de ser eliminados automáticamente."
                },
                "sharedMemoryMcp.status": {
                    "type": "string",
                    "default": "Activo",
                    "description": "Tu mensaje de estado actual (ej. 'En reunión', 'Codificando')."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "18.x",
        "typescript": "^5.1.3",
        "eslint": "^8.41.0",
        "@typescript-eslint/parser": "^5.59.8",
        "@typescript-eslint/eslint-plugin": "^5.59.8"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^0.6.0",
        "@supabase/supabase-js": "^2.38.4",
        "dotenv": "^16.3.1"
    }
}